# ============================================================
# OSINT Agent Network — Configuration Template
# Copy this file to .env and fill in your credentials.
# ============================================================

# ---- LLM (Required) ----
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-multimodal

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./oan.db
# For production: postgresql+asyncpg://user:pass@localhost:5432/oan

# ---- Redis / Celery ----
REDIS_URL=redis://localhost:6379/0

# ---- OSINT Integrations ----
# Shodan: https://account.shodan.io/
SHODAN_API_KEY=

# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=

# Censys: https://search.censys.io/account/api
CENSYS_API_ID=
CENSYS_API_SECRET=

# GreyNoise: https://www.greynoise.io/account
GREYNOISE_API_KEY=

# MISP (self-hosted)
MISP_URL=https://your-misp-instance.com
MISP_AUTH_KEY=

# ---- Social Media ----
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ---- App ----
DEBUG_MODE=false
MAX_RETRIES=3
LOG_LEVEL=INFO
# Comma-separated targets for scheduled daily scans
TARGET_KEYWORDS=APT29,APT32,Lazarus Group
